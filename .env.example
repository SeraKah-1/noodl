# ── Noodl + Supabase ─────────────────────────────────────────
# Copy to .env.local (gitignored). Never commit real secrets.

# Project URL (Settings → API / Data API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Client key — ONE of these (publishable preferred on new projects)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# OR legacy JWT anon key:
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Server only (Edge Functions / Node API) — NO VITE_ prefix ──
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# Optional: Management API for scripts/bootstrap-supabase.mjs
# SUPABASE_ACCESS_TOKEN=sbp_...

# Optional default Gemini key for local dev
# VITE_GEMINI_API_KEY=

# ── Cloudflare Turnstile (bot protection on sign-in) ─────────
# Site key = browser (VITE_). Secret = server only (Vercel /api).
# VITE_TURNSTILE_SITE_KEY=0x4AAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAA...
