# ── Noodl environment (copy to .env.local — never commit real keys) ──

# Optional cloud (Supabase). Leave empty for 100% local/guest mode.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: default Gemini key for dev only (users can also paste keys in Settings)
# VITE_GEMINI_API_KEY=

# Legacy Vertex flags (unused in public build — kept so old deploys don't crash)
# VITE_USE_FIREBASE_VERTEX_AI=false
# VITE_USE_VERTEX_AI=false
