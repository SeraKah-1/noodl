{
  "name": "noodl",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "node scripts/test-review-fixes.mjs && node scripts/test-cors-allowlist.mjs && node scripts/test-schema-security.mjs && node --test --experimental-strip-types tests/answerEvaluation.test.ts tests/quizImportValidation.test.ts",
    "supabase:bootstrap": "node scripts/bootstrap-supabase.mjs",
    "supabase:schema": "node scripts/apply-schema.mjs",
    "sync:check": "node -e \"console.log('Set .env.local, run npm run supabase:schema, then sign in')\""
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@mediapipe/tasks-vision": "0.10.35",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.49.1",
    "canvas-confetti": "^1.9.2",
    "framer-motion": "^12.33.2",
    "idb-keyval": "6.2.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "10.5.4",
    "katex": "^0.17.0",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.1",
    "@rollup/rollup-linux-arm64-gnu": "^4.62.2",
    "@rollup/rollup-linux-x64-gnu": "^4.62.2",
    "@rollup/wasm-node": "^4.62.2"
  },
  "description": "Noodl — turn notes into high-yield quizzes and actually remember them"
}
